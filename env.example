# ============================================
# WordPress CMS Configuration
# ============================================

# Your WordPress site URL (without trailing slash)
WORDPRESS_API_URL=https://your-wordpress-site.com

# WordPress hostname for image optimization (without protocol)
WORDPRESS_HOSTNAME=your-wordpress-site.com

# Direct IP used when site DNS points to Vercel instead of WordPress
WORDPRESS_SERVER_IP=

# Toggle VoiceCare custom content endpoints
WORDPRESS_CONTENT_ENABLED=true

# ============================================
# Site Configuration
# ============================================

# IMPORTANT: set this to your real production domain for same-domain Vercel cutover,
# e.g. https://voicecare.ai (no trailing slash).
# This value powers canonical URLs, sitemap, robots, and OG metadata.
NEXT_PUBLIC_SITE_URL=https://www.healthcareplus.com

# ============================================
# Analytics Integrations
# ============================================

# Google Analytics Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-QDTB37J1B8

# ============================================
# WordPress Forms & Revalidation
# ============================================

# Shared API key used by secure form submission endpoints
VOICECARE_FORM_API_KEY=

# Secret for /api/revalidate webhook endpoint
REVALIDATION_SECRET=

# Optional: override WordPress form IDs
NEXT_PUBLIC_WP_DEMO_FORM_ID=1671
NEXT_PUBLIC_WP_PARTNER_FORM_ID=3054
NEXT_PUBLIC_WP_NEWSLETTER_FORM_ID=3550
